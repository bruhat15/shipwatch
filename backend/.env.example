# === ShipWatch Backend ===
# Copy this file to .env and fill in the values

# GitHub Personal Access Token (free)
# Get one: https://github.com/settings/tokens
# Scopes needed: repo, read:org
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AI API Key (free tier - Gemini 2.5 Flash)
# Get one: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OAuth (GitHub + Google)
# GitHub OAuth App: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Add "repo" if you want to list or create GitHub issues
GITHUB_OAUTH_SCOPES=read:user user:email repo

# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT
JWT_SECRET=change_me
JWT_EXPIRE_HOURS=72

# App URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Backend config
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Coral CLI path (leave as 'coral' if it's in your PATH)
CORAL_CLI_PATH=coral

# Contact form SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
CONTACT_TO_EMAIL=example@gmail.com
